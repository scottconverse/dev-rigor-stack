# Normalize line endings so the shell and Node scripts run everywhere.
# Bash chokes on a CRLF shebang; keep .sh (and .js) LF on every checkout.
* text=auto
*.sh text eol=lf
*.js text eol=lf

# Hook payload markdown must checkout LF everywhere — the hooks inject these bytes verbatim.
plugin/*.md text eol=lf
plugin/disciplines/*.md text eol=lf
